#!/usr/bin/env bash
# awake — keep the Mac awake even with the lid closed.
#
# Usage:
#   awake                  Run in the foreground; Ctrl+C restores sleep and exits.
#   awake -t 1h            Run in the foreground for 1 hour, then auto-stop.
#   awake -b 20            Auto-stop when battery drops to 20% (on battery power).
#   awake start            Run in the background; persists across shell exit.
#   awake start -t 1h      Run in the background for 1 hour, then auto-stop.
#   awake status           Show whether awake is running and the pmset state.
#   awake stop             Stop a background awake started with `awake start`.
#   awake --help           Show help.

set -u

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "awake: macOS only" >&2
  exit 1
fi

STATE_DIR="${AWAKE_STATE_DIR:-$HOME/.local/state/awake}"
PID_FILE="$STATE_DIR/awake.pid"
DEADLINE_FILE="$STATE_DIR/awake.deadline"
BATTERY_FILE="$STATE_DIR/awake.battery"
LOG_FILE="$STATE_DIR/awake.log"

BATTERY_POLL_SECS=60

print_help() {
  cat <<'USAGE'
awake — keep the Mac awake even with the lid closed

Usage:
  awake                  Run in the foreground. Ctrl+C to release and exit.
  awake -t DURATION      Run in the foreground for DURATION, then auto-stop.
  awake -b PERCENT       Auto-stop when battery drops to PERCENT% (on battery).
  awake start            Run in the background (detached). Survives shell exit.
  awake start -t DURATION -b PERCENT
                         Run in the background with a time/battery limit.
  awake status           Show running state, PID, uptime, and pmset disablesleep.
  awake stop             Stop a background awake and restore sleep settings.
  awake -h|--help        Show this help.

Duration format (-t / --timeout):
  Combine units h/m/s, e.g. 1h, 30m, 45s, 1h30m, 2h15m30s.
  A bare integer is treated as seconds: `-t 3600` == `-t 1h`.

Battery threshold (-b / --battery):
  Integer 1-99. Auto-stops when battery percentage drops to or below this
  value while on battery power. Checks every 60s. Skipped while on AC power.

  -t and -b may be combined; whichever condition fires first stops awake.

State files:
  PID file:      $HOME/.local/state/awake/awake.pid
  Deadline file: $HOME/.local/state/awake/awake.deadline
  Battery file:  $HOME/.local/state/awake/awake.battery
  Log file:      $HOME/.local/state/awake/awake.log
  (Override the directory via AWAKE_STATE_DIR.)

Behavior:
  - Disables clamshell sleep via `sudo pmset -a disablesleep 1`
  - Prevents system idle sleep via `caffeinate -is`
  - Always restores pmset to 0 on graceful exit (Ctrl+C, SIGTERM, timeout, etc.)
USAGE
}

parse_battery_threshold() {
  local input="${1%\%}"  # tolerate a trailing '%' (e.g. `-b 20%`)
  if [[ ! "$input" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  if (( input < 1 || input > 99 )); then
    return 1
  fi
  printf '%s' "$input"
}

# Read current battery percentage (integer 0-100). Empty string if unavailable
# (e.g. desktop Mac without a battery).
battery_percent() {
  pmset -g batt 2>/dev/null | awk '
    match($0, /[0-9]+%/) {
      pct = substr($0, RSTART, RLENGTH - 1)
      print pct
      exit
    }
  '
}

# "ac" if currently on wall power, "battery" if discharging, "" if unknown.
power_source() {
  pmset -g batt 2>/dev/null | awk '
    /Now drawing from/ {
      if (index($0, "AC Power")) { print "ac"; exit }
      if (index($0, "Battery Power")) { print "battery"; exit }
    }
  '
}

# Parse a duration like "1h30m", "45s", "2h", or a bare integer (seconds).
# Prints the total seconds to stdout on success; exits non-zero on parse error.
parse_duration() {
  local input="$1"
  if [[ -z "$input" ]]; then
    return 1
  fi
  # Bare integer = seconds.
  if [[ "$input" =~ ^[0-9]+$ ]]; then
    if (( input <= 0 )); then
      return 1
    fi
    printf '%s' "$input"
    return 0
  fi
  # Combined units. Each unit may appear at most once and must be in h/m/s order.
  if [[ ! "$input" =~ ^([0-9]+h)?([0-9]+m)?([0-9]+s)?$ ]]; then
    return 1
  fi
  local h="${BASH_REMATCH[1]%h}"
  local m="${BASH_REMATCH[2]%m}"
  local s="${BASH_REMATCH[3]%s}"
  h="${h:-0}"; m="${m:-0}"; s="${s:-0}"
  local total=$(( h * 3600 + m * 60 + s ))
  if (( total <= 0 )); then
    return 1
  fi
  printf '%s' "$total"
}

pmset_disablesleep_value() {
  # `pmset -a disablesleep N` shows up under "System-wide power settings:" as
  # `SleepDisabled N`. Default is 0 when no override is set.
  pmset -g 2>/dev/null | awk '/SleepDisabled/ {print $2; exit}'
}

is_running() {
  local pid="$1"
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

read_pid() {
  [[ -f "$PID_FILE" ]] || return 1
  local pid
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  printf '%s' "$pid"
}

format_uptime() {
  local secs="$1"
  local d=$(( secs / 86400 ))
  local h=$(( (secs % 86400) / 3600 ))
  local m=$(( (secs % 3600) / 60 ))
  local s=$(( secs % 60 ))
  if (( d > 0 )); then
    printf '%dd %02dh %02dm %02ds' "$d" "$h" "$m" "$s"
  elif (( h > 0 )); then
    printf '%dh %02dm %02ds' "$h" "$m" "$s"
  elif (( m > 0 )); then
    printf '%dm %02ds' "$m" "$s"
  else
    printf '%ds' "$s"
  fi
}

# ---------- foreground runner (the actual work loop) ----------

run_foreground() {
  local mode="${1:-attached}"     # attached | detached
  local timeout_secs="${2:-0}"    # 0 = no timeout
  local battery_threshold="${3:-0}" # 0 = no battery limit

  CAFFEINATE_PID=""
  TIMER_PID=""
  BATTERY_PID=""
  DISABLED_SLEEP=0

  cleanup() {
    trap - INT TERM HUP EXIT

    if [[ -n "$TIMER_PID" ]] && kill -0 "$TIMER_PID" 2>/dev/null; then
      kill "$TIMER_PID" 2>/dev/null || true
      wait "$TIMER_PID" 2>/dev/null || true
    fi

    if [[ -n "$BATTERY_PID" ]] && kill -0 "$BATTERY_PID" 2>/dev/null; then
      kill "$BATTERY_PID" 2>/dev/null || true
      wait "$BATTERY_PID" 2>/dev/null || true
    fi

    if [[ -n "$CAFFEINATE_PID" ]] && kill -0 "$CAFFEINATE_PID" 2>/dev/null; then
      kill "$CAFFEINATE_PID" 2>/dev/null || true
      wait "$CAFFEINATE_PID" 2>/dev/null || true
    fi

    if [[ "$DISABLED_SLEEP" -eq 1 ]]; then
      echo ""
      echo "awake: restoring sleep settings (sudo pmset -a disablesleep 0)"
      sudo -n pmset -a disablesleep 0 \
        || sudo pmset -a disablesleep 0 \
        || echo "awake: failed to restore pmset. Run manually: sudo pmset -a disablesleep 0" >&2
    fi

    if [[ "$mode" == "detached" ]]; then
      rm -f "$PID_FILE" "$DEADLINE_FILE" "$BATTERY_FILE"
    fi
  }

  trap cleanup INT TERM HUP EXIT

  echo "awake: disabling sleep (sudo required)"
  if ! sudo pmset -a disablesleep 1; then
    echo "awake: failed to configure pmset" >&2
    exit 1
  fi
  DISABLED_SLEEP=1

  caffeinate -is &
  CAFFEINATE_PID=$!

  local parent=$$

  if (( timeout_secs > 0 )); then
    local deadline=$(( $(date +%s) + timeout_secs ))
    if [[ "$mode" == "detached" ]]; then
      echo "$deadline" > "$DEADLINE_FILE"
    fi
    # Timer child: after the timeout, signal our parent (this shell) so the
    # cleanup trap runs and pmset is restored. Using SIGTERM keeps the exit
    # path identical to `awake stop` / Ctrl+C.
    (
      sleep "$timeout_secs"
      kill -TERM "$parent" 2>/dev/null || true
    ) &
    TIMER_PID=$!
  fi

  if (( battery_threshold > 0 )); then
    if [[ "$mode" == "detached" ]]; then
      echo "$battery_threshold" > "$BATTERY_FILE"
    fi
    # Battery monitor child: polls pmset; signals parent when on battery and
    # at/below threshold. Skips polls while on AC power.
    (
      while sleep "$BATTERY_POLL_SECS"; do
        local src pct
        src="$(power_source)"
        if [[ "$src" != "battery" ]]; then
          continue
        fi
        pct="$(battery_percent)"
        if [[ -z "$pct" ]]; then
          continue
        fi
        if (( pct <= battery_threshold )); then
          echo "awake: battery at ${pct}% (<= ${battery_threshold}%); stopping" >&2
          kill -TERM "$parent" 2>/dev/null || true
          exit 0
        fi
      done
    ) &
    BATTERY_PID=$!
  fi

  local startup_msg="awake: running (PID=$$, caffeinate PID=$CAFFEINATE_PID"
  if (( timeout_secs > 0 )); then
    startup_msg+=", timeout=$(format_uptime "$timeout_secs")"
  fi
  if (( battery_threshold > 0 )); then
    startup_msg+=", battery<=${battery_threshold}%"
  fi
  startup_msg+=")"
  echo "$startup_msg"
  echo "awake: the Mac will stay awake with the lid closed. Press Ctrl+C to release and exit."

  while kill -0 "$CAFFEINATE_PID" 2>/dev/null; do
    wait "$CAFFEINATE_PID" 2>/dev/null
  done
}

# ---------- subcommands ----------

cmd_start() {
  local timeout_secs="${1:-0}"
  local battery_threshold="${2:-0}"
  mkdir -p "$STATE_DIR"

  if pid="$(read_pid)" && is_running "$pid"; then
    echo "awake: already running (PID=$pid). Use 'awake stop' first." >&2
    exit 1
  fi
  rm -f "$PID_FILE" "$DEADLINE_FILE" "$BATTERY_FILE"

  # Prime sudo in the foreground so the background child can use the cached
  # credential without prompting.
  echo "awake: priming sudo (you may be asked for your password)"
  sudo -v || { echo "awake: sudo authentication failed" >&2; exit 1; }

  # Re-exec self in the background, detached from this shell. Trailing args:
  # __detached <timeout_secs> <battery_threshold> (0 = unset).
  nohup "$0" __detached "$timeout_secs" "$battery_threshold" >>"$LOG_FILE" 2>&1 </dev/null &
  local child=$!
  disown "$child" 2>/dev/null || true

  # Wait briefly for the child to write its PID / start caffeinate.
  local waited=0
  while (( waited < 30 )); do
    if pid="$(read_pid)" && is_running "$pid"; then
      echo "awake: started in background (PID=$pid)"
      if (( timeout_secs > 0 )); then
        echo "awake: will auto-stop after $(format_uptime "$timeout_secs")"
      fi
      if (( battery_threshold > 0 )); then
        echo "awake: will auto-stop when battery drops to ${battery_threshold}% (on battery power)"
      fi
      echo "awake: logs -> $LOG_FILE"
      echo "awake: stop with 'awake stop'"
      return 0
    fi
    sleep 0.1
    waited=$(( waited + 1 ))
  done

  echo "awake: background process did not start cleanly. Check $LOG_FILE" >&2
  exit 1
}

cmd_detached() {
  local timeout_secs="${1:-0}"
  local battery_threshold="${2:-0}"
  mkdir -p "$STATE_DIR"
  echo "$$" > "$PID_FILE"
  run_foreground detached "$timeout_secs" "$battery_threshold"
}

cmd_status() {
  local pid="" running=0
  if pid="$(read_pid)" && is_running "$pid"; then
    running=1
  elif [[ -f "$PID_FILE" ]]; then
    echo "awake: stale PID file at $PID_FILE (process not running)"
  fi

  local disablesleep
  disablesleep="$(pmset_disablesleep_value)"
  disablesleep="${disablesleep:-unknown}"

  if (( running )); then
    local started_epoch now uptime started_raw
    # Force C locale so `ps` emits the parseable English form
    # ("Sat May 24 13:00:00 2026") regardless of the user's LANG.
    started_raw="$(LC_ALL=C ps -o lstart= -p "$pid" 2>/dev/null | awk '{$1=$1; print}')"
    if [[ -n "$started_raw" ]]; then
      started_epoch="$(date -j -f "%a %b %d %T %Y" "$started_raw" +%s 2>/dev/null || true)"
    fi
    now="$(date +%s)"

    echo "awake: running (background)"
    echo "  pid:                $pid"
    if [[ -n "$started_epoch" ]]; then
      echo "  started:            $(date -r "$started_epoch" "+%Y-%m-%d %H:%M:%S %Z")"
      uptime=$(( now - started_epoch ))
      echo "  uptime:             $(format_uptime "$uptime")"
    elif [[ -n "$started_raw" ]]; then
      echo "  started:            $started_raw"
    fi
    if [[ -f "$DEADLINE_FILE" ]]; then
      local deadline remaining
      deadline="$(cat "$DEADLINE_FILE" 2>/dev/null || true)"
      if [[ "$deadline" =~ ^[0-9]+$ ]]; then
        remaining=$(( deadline - now ))
        echo "  auto-stop at:       $(date -r "$deadline" "+%Y-%m-%d %H:%M:%S %Z")"
        if (( remaining > 0 )); then
          echo "  remaining:          $(format_uptime "$remaining")"
        else
          echo "  remaining:          (deadline passed; stopping shortly)"
        fi
      fi
    fi
    if [[ -f "$BATTERY_FILE" ]]; then
      local threshold pct src
      threshold="$(cat "$BATTERY_FILE" 2>/dev/null || true)"
      if [[ "$threshold" =~ ^[0-9]+$ ]]; then
        pct="$(battery_percent)"
        src="$(power_source)"
        echo "  battery threshold:  ${threshold}% (now ${pct:-?}%, source: ${src:-unknown})"
      fi
    fi
    echo "  pmset disablesleep: $disablesleep"
    echo "  log:                $LOG_FILE"
  else
    echo "awake: not running (background)"
    echo "  pmset disablesleep: $disablesleep"
    if [[ "$disablesleep" == "1" ]]; then
      echo "  warning: disablesleep is 1 but no awake process is tracked."
      echo "  another tool may hold it, or a prior awake was force-killed."
      echo "  inspect with: pmset -g assertions"
      echo "  restore with: sudo pmset -a disablesleep 0"
    fi
  fi
}

cmd_stop() {
  local pid
  if ! pid="$(read_pid)"; then
    echo "awake: no PID file at $PID_FILE — nothing to stop"
    local disablesleep
    disablesleep="$(pmset_disablesleep_value)"
    if [[ "$disablesleep" == "1" ]]; then
      echo "awake: warning: pmset disablesleep is still 1"
      echo "  restore with: sudo pmset -a disablesleep 0"
    fi
    exit 1
  fi

  if ! is_running "$pid"; then
    echo "awake: PID $pid not running — cleaning up stale PID file"
    rm -f "$PID_FILE" "$DEADLINE_FILE" "$BATTERY_FILE"
    local disablesleep
    disablesleep="$(pmset_disablesleep_value)"
    if [[ "$disablesleep" == "1" ]]; then
      echo "awake: warning: pmset disablesleep is still 1 (previous run may have been force-killed)"
      echo "  restore with: sudo pmset -a disablesleep 0"
    fi
    exit 0
  fi

  echo "awake: stopping PID $pid"
  kill -TERM "$pid" 2>/dev/null || { echo "awake: kill failed" >&2; exit 1; }

  local waited=0
  while (( waited < 50 )); do
    if ! is_running "$pid"; then
      echo "awake: stopped"
      return 0
    fi
    sleep 0.1
    waited=$(( waited + 1 ))
  done

  echo "awake: process did not exit after SIGTERM; sending SIGKILL"
  kill -KILL "$pid" 2>/dev/null || true
  rm -f "$PID_FILE" "$DEADLINE_FILE" "$BATTERY_FILE"
  local disablesleep
  disablesleep="$(pmset_disablesleep_value)"
  if [[ "$disablesleep" == "1" ]]; then
    echo "awake: warning: cleanup trap did not run; pmset disablesleep is still 1"
    echo "  restore with: sudo pmset -a disablesleep 0"
  fi
}

# ---------- dispatch ----------

# Extract a subcommand and -t/--timeout flag from arbitrary argv order.
# Recognized subcommands: (empty)|fg|foreground|start|status|stop|__detached
# -t/--timeout DURATION may appear before or after the subcommand.
SUBCMD=""
TIMEOUT_RAW=""
BATTERY_RAW=""
DETACHED_TIMEOUT_SECS=""
DETACHED_BATTERY_THRESHOLD=""

while (( $# > 0 )); do
  case "$1" in
    -h|--help)
      print_help
      exit 0
      ;;
    -t|--timeout)
      if (( $# < 2 )); then
        echo "awake: $1 requires a DURATION argument (e.g. 1h, 30m, 90s, 3600)" >&2
        exit 2
      fi
      TIMEOUT_RAW="$2"
      shift 2
      ;;
    --timeout=*)
      TIMEOUT_RAW="${1#--timeout=}"
      shift
      ;;
    -t*)
      # Allow `-t1h` (no space).
      TIMEOUT_RAW="${1#-t}"
      shift
      ;;
    -b|--battery)
      if (( $# < 2 )); then
        echo "awake: $1 requires a PERCENT argument (integer 1-99)" >&2
        exit 2
      fi
      BATTERY_RAW="$2"
      shift 2
      ;;
    --battery=*)
      BATTERY_RAW="${1#--battery=}"
      shift
      ;;
    -b*)
      # Allow `-b20` (no space).
      BATTERY_RAW="${1#-b}"
      shift
      ;;
    fg|foreground|start|status|stop)
      if [[ -n "$SUBCMD" ]]; then
        echo "awake: unexpected extra argument: $1" >&2
        exit 2
      fi
      SUBCMD="$1"
      shift
      ;;
    __detached)
      # Internal: invoked by `awake start` via nohup. Not a public subcommand.
      # Expects: __detached <timeout_secs> <battery_threshold>
      SUBCMD="__detached"
      shift
      DETACHED_TIMEOUT_SECS="${1:-0}"
      shift || true
      DETACHED_BATTERY_THRESHOLD="${1:-0}"
      shift || true
      ;;
    *)
      echo "awake: unknown argument: $1" >&2
      echo "Run 'awake --help' for usage." >&2
      exit 2
      ;;
  esac
done

TIMEOUT_SECS=0
if [[ -n "$TIMEOUT_RAW" ]]; then
  if ! TIMEOUT_SECS="$(parse_duration "$TIMEOUT_RAW")"; then
    echo "awake: invalid duration: '$TIMEOUT_RAW' (use 1h, 30m, 45s, 1h30m, or a positive integer of seconds)" >&2
    exit 2
  fi
fi

BATTERY_THRESHOLD=0
if [[ -n "$BATTERY_RAW" ]]; then
  if ! BATTERY_THRESHOLD="$(parse_battery_threshold "$BATTERY_RAW")"; then
    echo "awake: invalid battery threshold: '$BATTERY_RAW' (use an integer 1-99, with or without %)" >&2
    exit 2
  fi
fi

case "$SUBCMD" in
  ""|fg|foreground)
    run_foreground attached "$TIMEOUT_SECS" "$BATTERY_THRESHOLD"
    ;;
  start)
    cmd_start "$TIMEOUT_SECS" "$BATTERY_THRESHOLD"
    ;;
  status)
    cmd_status
    ;;
  stop)
    cmd_stop
    ;;
  __detached)
    cmd_detached "$DETACHED_TIMEOUT_SECS" "$DETACHED_BATTERY_THRESHOLD"
    ;;
esac
